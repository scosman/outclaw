{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "OutClaw",
	"version": "0.3.1",
	"identifier": "net.scosman.outclaw",
	"build": {
		"beforeDevCommand": "npm run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "npm run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "OutClaw",
				"width": 900,
				"height": 640,
				"minWidth": 720,
				"minHeight": 500,
				"resizable": true
			}
		],
		"security": {
			"csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"signingIdentity": "-"
		}
	}
}
